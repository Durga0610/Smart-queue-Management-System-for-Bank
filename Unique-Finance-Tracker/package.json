{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "node -e \"if(process.env.npm_execpath.indexOf('pnpm') === -1) { console.error('Use pnpm instead'); process.exit(1); }\"",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./frontend\" --filter \"./backend\" --filter \"./database\" --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "dev": "pnpm.cmd -r --parallel run dev",
    "db:push": "pnpm.cmd --filter @workspace/db run push"
  },
  "private": true,
  "devDependencies": {
    "cross-env": "^10.1.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
  "dependencies": {
    "@types/nodemailer": "^8.0.0",
    "nodemailer": "^8.0.7",
    "twilio": "^6.0.0",
    "zod": "catalog:"
  }
}
